#include <stdio.h>

int main() {
float myArray[3][3] = { { 0.1, 0.2, 0.3 }, { 1.1, 1.2, 1.3 }, { 2.1,
2.2, 2.3 } };
float mean;
int i, ii;
for (i=0; i<3; i++) {
	for (ii=0; ii<3; ii++) {
		mean += myArray[i][ii];
	}
}
mean /= 9;
printf("%f\n", mean);
return 0;
}
