#include <stdio.h>
#include <stdlib.h>
#include <limits.h>

void zeroInt(int *x);

int main() {
	int *x, y = 3;
	x = &y;
	printf("%d\n", y);
	zeroInt(x);
	printf("%d\n", y);
	return 0;
}

void zeroInt(int *x) {
	*x = 0;
}

